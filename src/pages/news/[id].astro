---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateFmt = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${post.data.title} — BioGenAI Solutions`} description={post.data.summary}>
  <Navbar />
  <main>
    <article class="section article">
      <div class="container article-inner">
        <a href="/#news" class="article-back">← Back to News</a>
        <span class="news-date">{dateFmt}</span>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-summary">{post.data.summary}</p>
        {post.data.thumbnail && (
          <div class="article-media"><img src={post.data.thumbnail} alt={post.data.title} /></div>
        )}
        <div class="article-body">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .article-inner { max-width: 760px; }
  .article-back {
    display: inline-block;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 14px;
    color: var(--slate-dark);
    margin-bottom: 24px;
  }
  .article-back:hover { color: #a83bf7; }
  .article-title {
    font-size: clamp(30px, 4.5vw, 46px);
    margin: 14px 0 16px;
  }
  .article-summary { font-size: 20px; color: var(--muted); margin-bottom: 28px; }
  .article-media {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 32px;
    border: 1px solid var(--border);
  }
  .article-media img { width: 100%; display: block; }
  .article-body { font-size: 18px; color: var(--ink); line-height: 1.75; }
  .article-body :global(p) { margin-bottom: 20px; }
  .article-body :global(h2) { font-family: var(--font-head); margin: 32px 0 12px; font-size: 26px; }
  .article-body :global(a) { color: #a83bf7; text-decoration: underline; }
</style>

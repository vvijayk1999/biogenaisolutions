---
import general from '../content/site/general.json';
---
<header class="navbar" id="navbar">
  <div class="container nav-inner">
    <a href="#home" class="brand" aria-label={`${general.brandName} ${general.brandAccent} home`}>
      <img src="/logo.png" alt={`${general.brandName} ${general.brandAccent} logo`} class="brand-logo" />
      <span class="brand-name">{general.brandName}<span class="brand-name-accent"> {general.brandAccent}</span></span>
    </a>

    <nav class="nav-links" id="navLinks" aria-label="Primary">
      <a href="#home" class="nav-link">Home</a>
      <a href="#solutions" class="nav-link">Solutions</a>
      <a href="#services" class="nav-link">Services</a>
      <a href="#research" class="nav-link">Research</a>
      <a href="#news" class="nav-link">News</a>
      <a href="#about" class="nav-link">About</a>
      <div class="nav-mobile-cta">
        <a href="#contact" class="btn btn-gradient nav-cta">Contact</a>
      </div>
    </nav>

    <div class="nav-actions">
      <div class="lang-select" id="langSelect">
        <button class="lang-trigger" aria-haspopup="true" aria-expanded="false" id="langTrigger" title="Select language">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18M12 3c2.5 2.7 3.8 6 3.8 9s-1.3 6.3-3.8 9c-2.5-2.7-3.8-6-3.8-9S9.5 5.7 12 3z"></path>
          </svg>
          <span class="lang-current" id="langCurrent">EN</span>
          <svg class="chev" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <ul class="lang-menu" role="menu" aria-label="Language">
          <li role="menuitem" data-lang="EN" class="active">English</li>
          <li role="menuitem" data-lang="ES">Spanish</li>
          <li role="menuitem" data-lang="AR">Arabic</li>
          <li role="menuitem" data-lang="FR">French</li>
          <li role="menuitem" data-lang="DE">German</li>
        </ul>
      </div>

      <a href="#contact" class="btn btn-gradient nav-cta-desktop">Contact Us</a>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

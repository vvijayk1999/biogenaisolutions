---
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

export interface Props {
  title: string;
  updated?: string;
}
const { title, updated = 'June 2026' } = Astro.props;
---
<Layout title={`${title} — BioGenAI Solutions`} description={`${title} for BioGenAI Solutions.`}>
  <Navbar />
  <main>
    <article class="section">
      <div class="container legal-inner">
        <a href="/" class="legal-back">← Back to Home</a>
        <h1 class="section-title legal-title">{title}</h1>
        <p class="legal-updated">Last updated: {updated}</p>
        <div class="legal-body">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .legal-inner { max-width: 760px; }
  .legal-back { display:inline-block; font-family:var(--font-head); font-weight:700; font-size:14px; color:var(--slate-dark); margin-bottom:22px; }
  .legal-back:hover { color:#a83bf7; }
  .legal-title { text-align:left; }
  .legal-updated { color:var(--slate); font-size:14px; margin:10px 0 28px; }
  .legal-body { color:var(--muted); font-size:17px; line-height:1.75; }
  .legal-body :global(h2) { font-family:var(--font-head); color:var(--ink); font-size:22px; margin:28px 0 10px; }
  .legal-body :global(p) { margin-bottom:16px; }
</style>

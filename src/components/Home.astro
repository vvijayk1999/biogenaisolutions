---
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { getCollection } from 'astro:content';
import { getContent, formatDate, DEFAULT_LOCALE, type Locale } from '../i18n';

export interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const c = getContent(locale);

// News in this locale, falling back to default-locale posts if none exist yet.
const published = await getCollection('news', ({ data }) => !data.draft);
let news = published.filter((p) => (p.data.lang ?? DEFAULT_LOCALE) === locale);
if (news.length === 0) news = published.filter((p) => (p.data.lang ?? DEFAULT_LOCALE) === DEFAULT_LOCALE);
news = news.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Navbar locale={locale} />

<main>
  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">{c.hero.eyebrow}</span>
        <h1 class="hero-title">
          {c.hero.titleLead} <span class="gradient-text">{c.hero.titleHighlight}</span> {c.hero.titleTrail}
        </h1>
        <p class="hero-sub">{c.hero.subtitle}</p>
        <div class="hero-cta">
          <a href="#contact" class="btn btn-gradient btn-lg">{c.hero.ctaPrimaryLabel}</a>
          <a href="#solutions" class="btn btn-ghost btn-lg">{c.hero.ctaSecondaryLabel}</a>
        </div>
        <ul class="hero-trust">
          {c.hero.stats.map((s) => (<li><strong>{s.value}</strong> {s.label}</li>))}
        </ul>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="hero-card">
          <img src="/logo.png" alt="" class="hero-logo" />
          <div class="hero-card-glow"></div>
          <div class="hero-tags">
            {c.hero.tags.map((t) => <span>{t}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES STRIP -->
  <section class="strip" aria-label="Core capabilities">
    <div class="container strip-inner">
      <span class="strip-label">{c.ui.capabilitiesLabel}</span>
      <ul class="strip-items">
        {c.general.capabilities.map((cap) => <li>{cap}</li>)}
      </ul>
    </div>
  </section>

  <!-- SOLUTIONS -->
  <section class="section" id="solutions">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.solutions.eyebrow}</span>
        <h2 class="section-title">{c.solutions.heading}</h2>
        <p class="section-lead">{c.solutions.lead}</p>
      </div>
      <div class="grid grid-3">
        {c.solutions.items.map((item) => (
          <article class="card">
            <div class="card-icon" data-icon={item.icon}></div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section-alt" id="services">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.services.eyebrow}</span>
        <h2 class="section-title">{c.services.heading}</h2>
        <p class="section-lead">{c.services.lead}</p>
      </div>
      <div class="grid grid-2 services-grid">
        {c.services.items.map((item) => (
          <div class="service-row">
            <span class="service-no">{item.number}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAROUSEL: INDUSTRIES -->
  <section class="section carousel-section" id="industries">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.carousel.eyebrow}</span>
        <h2 class="section-title">{c.carousel.heading}</h2>
        <p class="section-lead">{c.carousel.lead}</p>
      </div>

      <div class="carousel" id="carousel">
        <button class="carousel-arrow carousel-prev" id="carouselPrev" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="carousel-viewport">
          <ul class="carousel-track" id="carouselTrack">
            {c.carousel.slides.map((s, i) => (
              <li class="carousel-slide">
                <div class="carousel-card">
                  <span class="carousel-badge">{String(i + 1).padStart(2, '0')}</span>
                  <h3>{s.title}</h3>
                  <p>{s.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <button class="carousel-arrow carousel-next" id="carouselNext" aria-label="Next">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
      <div class="carousel-dots" id="carouselDots" role="tablist" aria-label="Carousel navigation"></div>
    </div>
  </section>

  <!-- VISION / MISSION / PHILOSOPHY -->
  <section class="section" id="principles">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.principles.eyebrow}</span>
        <h2 class="section-title">{c.principles.heading}</h2>
      </div>
      <div class="grid grid-3">
        <article class="pillar">
          <div class="pillar-bar"></div>
          <h3>{c.principles.visionLabel}</h3>
          <p>{c.principles.vision}</p>
        </article>
        <article class="pillar">
          <div class="pillar-bar"></div>
          <h3>{c.principles.missionLabel}</h3>
          <p>{c.principles.mission}</p>
        </article>
        <article class="pillar">
          <div class="pillar-bar"></div>
          <h3>{c.principles.philosophyLabel}</h3>
          <p>{c.principles.philosophy}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section section-alt" id="about">
    <div class="container about-inner">
      <div class="about-copy">
        <span class="eyebrow">{c.about.eyebrow}</span>
        <h2 class="section-title">{c.about.heading}</h2>
        {c.about.paragraphs.map((p) => <p>{p}</p>)}
        <div class="founder">
          <div class="founder-avatar" aria-hidden="true">{c.about.founderInitials}</div>
          <div class="founder-info">
            <h3>{c.about.founderName}</h3>
            <p class="founder-role">{c.about.founderRole}</p>
            <p class="founder-bio">{c.about.founderBio}</p>
          </div>
        </div>
      </div>
      <aside class="about-stats">
        {c.about.stats.map((s) => (
          <div class="stat">
            <span class="stat-num gradient-text">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </aside>
    </div>
  </section>

  <!-- RESEARCH -->
  <section class="section" id="research">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.research.eyebrow}</span>
        <h2 class="section-title">{c.research.heading}</h2>
        <p class="section-lead">{c.research.lead}</p>
      </div>
      <div class="grid grid-2">
        {c.research.items.map((item) => (
          <a class="research-card" href={item.url} target="_blank" rel="noopener noreferrer">
            <span class="research-tag">{item.tag}</span>
            <h3>{item.title}</h3>
            <p class="research-author">{item.author}</p>
            <span class="research-link">{c.ui.readPaper}
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
            </span>
          </a>
        ))}
        <div class="research-card research-soon" aria-hidden="true">
          <span class="research-tag">{c.research.comingSoonTag}</span>
          <h3>{c.research.comingSoonTitle}</h3>
          <p class="research-author">{c.research.comingSoonText}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWS -->
  <section class="section section-alt" id="news">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.ui.nav.news}</span>
        <h2 class="section-title">{c.ui.newsHeading}</h2>
        <p class="section-lead">{c.ui.newsLead}</p>
      </div>

      {news.length > 0 ? (
        <div class="news-grid">
          {news.map((post) => (
            <article class="news-card">
              {post.data.thumbnail && (
                <div class="news-card-media"><img src={post.data.thumbnail} alt={post.data.title} /></div>
              )}
              <div class="news-card-body">
                <span class="news-date">{formatDate(post.data.date, locale)}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.summary}</p>
                <a class="research-link" href={`/news/${post.id}`}>{c.ui.readMore}
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="news-empty">
          <div class="news-empty-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h13a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zM8 8h8M8 12h8M8 16h5"/></svg>
          </div>
          <h3>{c.ui.newsEmptyTitle}</h3>
          <p>{c.ui.newsEmptyText}</p>
          <a href="#contact" class="btn btn-outline">{c.ui.newsKeepUpdated}</a>
        </div>
      )}
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <div class="container contact-inner">
      <div class="contact-copy">
        <span class="eyebrow">{c.contact.eyebrow}</span>
        <h2 class="section-title">{c.contact.heading}</h2>
        <p class="section-lead">{c.contact.lead}</p>
        <ul class="contact-points">
          <li>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="m4 6 8 6 8-6"/></svg>
            <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            {c.contact.responseTime}
          </li>
        </ul>
      </div>

      <form class="contact-form" id="contactForm" action={`mailto:${c.contact.email}`} method="post" enctype="text/plain" novalidate>
        <div class="form-row">
          <div class="field">
            <label for="firstName">{c.ui.form.firstName} <span class="req">*</span></label>
            <input type="text" id="firstName" name="First Name" required autocomplete="given-name" />
          </div>
          <div class="field">
            <label for="lastName">{c.ui.form.lastName} <span class="req">*</span></label>
            <input type="text" id="lastName" name="Last Name" required autocomplete="family-name" />
          </div>
        </div>
        <div class="form-row">
          <div class="field">
            <label for="email">{c.ui.form.email} <span class="req">*</span></label>
            <input type="email" id="email" name="Email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="jobTitle">{c.ui.form.jobTitle} <span class="req">*</span></label>
            <input type="text" id="jobTitle" name="Job Title" required autocomplete="organization-title" />
          </div>
        </div>
        <div class="form-row">
          <div class="field">
            <label for="company">{c.ui.form.company} <span class="req">*</span></label>
            <input type="text" id="company" name="Company" required autocomplete="organization" />
          </div>
          <div class="field">
            <label for="interest">{c.ui.form.interest} <span class="req">*</span></label>
            <select id="interest" name="Interested In" required>
              <option value="" disabled selected>{c.ui.form.interestPlaceholder}</option>
              {c.contact.interests.map((i) => <option>{i}</option>)}
            </select>
          </div>
        </div>
        <div class="field">
          <label for="comments">{c.ui.form.comments} <span class="req">*</span></label>
          <textarea id="comments" name="Comments" rows="5" required placeholder={c.ui.form.commentsPlaceholder}></textarea>
        </div>

        <div class="recaptcha-note">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5z"/><path d="m9 12 2 2 4-4"/></svg>
          {c.ui.form.recaptcha}
        </div>

        <button type="submit" class="btn btn-gradient btn-lg btn-block">{c.ui.form.submit}</button>

        <p class="form-success" id="formSuccess" role="status" hidden>{c.ui.form.success}</p>

        <p class="disclaimer">{c.contact.disclaimer}</p>
      </form>
    </div>
  </section>
</main>

<Footer locale={locale} />
